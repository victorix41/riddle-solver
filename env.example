# Copy to .env and fill in for your environment (or set these directly in Render's dashboard).

# Where Ollama is reachable from wherever this FastAPI app runs.
# - Local dev (FastAPI and Ollama on same laptop): http://localhost:11434
# - Deployed to Render: this must be a URL Render's servers can reach, e.g. a tunnel
#   into your laptop (ngrok/Tailscale Funnel) or a hosted Ollama instance. Render's
#   servers CANNOT reach "localhost" on your own laptop.
OLLAMA_HOST=http://localhost:11434

# Default model name
OLLAMA_MODEL=llama3.2

# Comma-separated list of allowed frontend origins (tighten this before going public).
# Example for a Vercel-hosted frontend:
# ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=*
